generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Utilisateur générique
model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLogin     DateTime?
  accountStatus String     @default("pending") // "active", "pending", "blocked"
  userType      String     // "admin", "volunteer", "beneficiary"

  // Relations
  admin         Admin?
  volunteer     Volunteer?
  beneficiary   Beneficiary?

  @@map("users")
}

// Administrateur
model Admin {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  phone     String?

  // Relation avec User
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique

  // Documents ajoutés pour le RAG
  documents KnowledgeDocument[]

  @@map("administrators")
}

// Bénévole
model Volunteer {
  id              String     @id @default(uuid())
  firstName       String
  lastName        String
  birthDate       DateTime
  phone           String
  experience      Int?       @default(0)
  skills          Json?
  availability    Json?
  trainings       Json?
  specializations Json?
  verified        Boolean    @default(false)

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String     @unique

  diagnostics     Diagnostic[]

  @@map("volunteers")
}

// Bénéficiaire
model Beneficiary {
  id                    String           @id @default(uuid())
  firstName             String
  lastName              String
  birthDate             DateTime
  phone                 String?
  address               String?
  city                  String?
  postalCode            String?
  familySituation       String?
  householdSize         Int?             @default(1)
  professionalSituation String?
  housingType           String?
  monthlyIncome         Int?
  priorityNeeds         Json?
  photoUrl              String?

  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String           @unique

  diagnostics           Diagnostic[]
  aids                  BeneficiaryAid[]
  faceEmbedding         FaceEmbedding?

  @@map("beneficiaries")
}

// Diagnostic
model Diagnostic {
  id              String    @id @default(uuid())
  diagnosticDate  DateTime  @default(now())
  status          String    @default("pending") // "pending", "in_progress", "completed", "follow_up"
  formResponses   Json?
  results         Json?
  recommendations Json?
  suggestedAids   Json?
  nextSteps       String?
  pdfUrl          String?
  version         String?

  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id])

  volunteerId     String?
  volunteer       Volunteer?  @relation(fields: [volunteerId], references: [id])

  @@map("diagnostics")
}

// Diagnostic sans compte
model AnonymousDiagnostic {
  id              String   @id @default(uuid())
  diagnosticDate  DateTime @default(now())
  formResponses   Json
  results         Json?
  recommendations Json?
  suggestedAids   Json?
  nextSteps       String?
  pdfUrl          String?
  version         String?
}

// Aide disponible
model AidType {
  id                  String            @id @default(uuid())
  name                String
  description         String
  eligibilityCriteria Json?

  beneficiaryAids     BeneficiaryAid[]

  @@map("aid_types")
}

// Aide attribuée à un bénéficiaire
model BeneficiaryAid {
  id           String     @id @default(uuid())
  status       String     @default("requested") // "requested", "approved", "rejected", "provided"
  requestDate  DateTime   @default(now())
  decisionDate DateTime?
  notes        String?

  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id])

  aidTypeId     String
  aidType       AidType     @relation(fields: [aidTypeId], references: [id])

  @@map("beneficiary_aids")
}

// Embedding facial (Face ID)
model FaceEmbedding {
  id             String      @id @default(uuid())
  beneficiaryId  String      @unique
  embedding      Json
  imageUrl       String
  createdAt      DateTime    @default(now())

  beneficiary    Beneficiary @relation(fields: [beneficiaryId], references: [id])
}

// Documents pour le chatbot (RAG)
model KnowledgeDocument {
  id          String   @id @default(uuid())
  title       String
  content     String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uploadedBy  String?
  admin       Admin?   @relation(fields: [uploadedBy], references: [id])
}
